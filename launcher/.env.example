# Copy to `.env.local` for local dev, or set these in your host's dashboard
# (Vercel → Project → Settings → Environment Variables).

# Where the Socket.io matchmaker is deployed. Use your Railway URL in prod.
VITE_MATCHMAKING_URL=https://your-matchmaker.up.railway.app

# Where the native game binaries live. Defaults to the GitHub Releases page.
VITE_DOWNLOADS_BASE=https://github.com/david20jin-ui/FPS-game/releases/latest/download
